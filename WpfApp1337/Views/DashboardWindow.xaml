<Window x:Class="ApplianceStoreIS.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Панель управления — Магазин бытовой техники" Height="640" Width="1040" MinWidth="920" MinHeight="580"
        WindowStartupLocation="CenterScreen" Icon="{StaticResource AppWindowIcon}">
    <Grid Background="#F4F6F8" Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock x:Name="UserHeaderTextBlock" FontSize="18" FontWeight="Bold"/>
            <Button Content="Выйти" Width="100" HorizontalAlignment="Right" DockPanel.Dock="Right" Click="OnLogoutClick"/>
        </DockPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="10" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="190"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Поиск:" VerticalAlignment="Center" Grid.Column="0"/>
                <TextBox x:Name="SearchTextBox" Grid.Column="1" Margin="4,0" TextChanged="OnFilterChanged"/>

                <TextBlock Text="Фильтр:" VerticalAlignment="Center" Grid.Column="2" Margin="12,0,0,0"/>
                <ComboBox x:Name="CategoryFilterComboBox" Grid.Column="3" Margin="4,0" SelectionChanged="OnFilterChanged"/>

                <TextBlock Text="Сорт:" VerticalAlignment="Center" Grid.Column="4" Margin="12,0,0,0"/>
                <ComboBox x:Name="SortComboBox" Grid.Column="5" Margin="4,0" SelectionChanged="OnSortChanged"/>
            </Grid>
        </Border>

        <TabControl Grid.Row="2" x:Name="TablesTabControl">
            <TabItem Header="Общая таблица (Товары)">
                <Grid Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="ProductsDataGrid" AutoGenerateColumns="False" IsReadOnly="True" CanUserResizeColumns="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="170"/>
                            <DataGridTextColumn Header="Бренд" Binding="{Binding Brand}" Width="120"/>
                            <DataGridTextColumn Header="Цена" Binding="{Binding Price}" Width="120"/>
                            <DataGridTextColumn Header="Количество" Binding="{Binding Quantity}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button x:Name="AddToCartButton" Content="В корзину" Width="110" Margin="0,0,8,0" Click="OnAddToCartClick"/>
                        <Button x:Name="AddProductButton" Content="Добавить" Width="110" Margin="0,0,8,0" Click="OnAddProductClick"/>
                        <Button x:Name="EditProductButton" Content="Изменить" Width="110" Margin="0,0,8,0" Click="OnEditProductClick"/>
                        <Button x:Name="DeleteProductButton" Content="Удалить" Width="110" Click="OnDeleteProductClick"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Личный кабинет и корзина">
                <Grid Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="ProfileTextBlock" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <DataGrid x:Name="CartDataGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" CanUserResizeColumns="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID товара" Binding="{Binding ProductId}" Width="90"/>
                            <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Цена" Binding="{Binding UnitPrice}" Width="120"/>
                            <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="100"/>
                            <DataGridTextColumn Header="Сумма" Binding="{Binding TotalPrice}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <TextBlock x:Name="CartTotalTextBlock" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,16,0"/>
                        <Button Content="Удалить из корзины" Width="150" Margin="0,0,8,0" Click="OnRemoveFromCartClick"/>
                        <Button Content="Оформить заказ" Width="130" Click="OnCheckoutClick"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem x:Name="SuppliersTab" Header="Поставщики">
                <DataGrid ItemsSource="{Binding Suppliers}" IsReadOnly="True" AutoGenerateColumns="False" Margin="6">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80"/>
                        <DataGridTextColumn Header="Поставщик" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Телефон" Binding="{Binding ContactPhone}" Width="180"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem x:Name="OrdersTab" Header="Заказы">
                <DataGrid x:Name="OrdersDataGrid" IsReadOnly="True" AutoGenerateColumns="False" Margin="6">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80"/>
                                                <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="*"/>
                        <DataGridTextColumn Header="Количество" Binding="{Binding Quantity}" Width="120"/>
                        <DataGridTextColumn Header="Дата" Binding="{Binding OrderDate}" Width="150"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="140"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
